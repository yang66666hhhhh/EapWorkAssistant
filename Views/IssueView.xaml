<UserControl x:Class="EapWorkAssistant.Views.IssueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             FontFamily="{StaticResource DefaultFont}">
    <Grid>
        <!-- 内层内容区域（带边距） -->
        <Grid Margin="28,24">

        <!-- ===== 主区域 ===== -->
        <DockPanel>

            <!-- 顶部栏 -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="问题跟踪" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="记录设备问题、根本原因和解决方案"
                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#x1F50D;" FontSize="13" VerticalAlignment="Center"
                                           Margin="8,0,6,0" Opacity="0.45"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchKeyword}" Width="180" BorderThickness="0"
                                         Background="Transparent" VerticalContentAlignment="Center"
                                         Padding="4,7" FontSize="13"
                                         FontFamily="{StaticResource DefaultFont}"/>
                            </Grid>
                        </Border>
                        <Button Content="搜索" Command="{Binding SearchCommand}"
                                Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Padding="16,9"/>
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="14,0"/>
                        <Button x:Name="OpenFormBtn" Click="OpenForm_Click"
                                Style="{StaticResource BtnPrimary}" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="新增问题" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 数据表格 -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0"
                    ClipToBounds="True">
                <Grid>
                    <DataGrid ItemsSource="{Binding Items}" Style="{StaticResource ModernGrid}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernGridColumnHeader}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernGridCell}"/>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernGridRow}"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="任务" Binding="{Binding ProjectName}" Width="140"/>
                            <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="根本原因" Binding="{Binding RootCause}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="关键词" Binding="{Binding Keywords}" Width="120"/>
                            <DataGridTemplateColumn Header="操作" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="编辑"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"/>
                                            <Button Content="删除"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"
                                                    Foreground="{DynamicResource DangerBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 空状态 -->
                    <Border Visibility="{Binding Items.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                            Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Background="{DynamicResource CardBrush}" CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F527;" FontSize="48" HorizontalAlignment="Center" Opacity="0.25"/>
                            <TextBlock Text="暂无问题记录" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                            <TextBlock Text="点击右上角「新增问题」按钮记录设备问题和解决方案" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
        </Grid>
        <!-- 关闭内层 Margin Grid -->

        <!-- ===== 遮罩层（浮窗打开时显示，覆盖整个视图） ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（从右侧滑入覆盖） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="500">
            <DockPanel>
                <!-- 表单标题（固定在顶部） -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="&#x1F50D; 问题详情" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="记录设备问题与解决方案" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button x:Name="CloseFormBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Click="CloseForm_Click" Style="{StaticResource BtnGhost}"
                                Padding="8,6" ToolTip="关闭面板">
                            <TextBlock Text="&#x2715;" FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮（固定在底部） -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                    <Grid>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="26,10"/>
                        <Button Content="新建" Command="{Binding NewCommand}"
                                Style="{StaticResource BtnSecondary}" HorizontalAlignment="Right"
                                Padding="20,10"/>
                    </Grid>
                    <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="10"
                            Padding="14,10" Margin="0,10,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="13" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <!-- 表单字段区域 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,0,0,16">
                        <!-- 任务 + 标题（并排） -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="任务 *" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding CurrentItem.ProjectName}"
                                          Style="{StaticResource Select}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="标题 *" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding CurrentItem.Title}" Style="{StaticResource Input}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,14"/>

                        <!-- 问题描述 -->
                        <TextBlock Text="描述 *" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Description}" Height="80" Style="{StaticResource TextArea}"
                                 Margin="0,0,0,14" VerticalScrollBarVisibility="Auto"/>

                        <!-- 根本原因 -->
                        <TextBlock Text="根本原因" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.RootCause}" Height="80" Style="{StaticResource TextArea}"
                                 Margin="0,0,0,14" VerticalScrollBarVisibility="Auto"/>

                        <!-- 解决方案 -->
                        <TextBlock Text="解决方案" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Solution}" Height="80" Style="{StaticResource TextArea}"
                                 Margin="0,0,0,18" VerticalScrollBarVisibility="Auto"/>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,18"/>

                        <!-- 关键词 -->
                        <TextBlock Text="关键词" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Keywords}" Style="{StaticResource Input}"
                                 Margin="0,0,0,6"/>
                        <TextBlock Text="多个关键词用逗号分隔，便于搜索检索" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
