<Window x:Class="EapWorkAssistant.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize">
    <Border Background="White" CornerRadius="14" Margin="16"
            Effect="{StaticResource ShadowLg}">
        <Grid Margin="28,22,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题行 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <Border x:Name="IconBorder" Width="32" Height="32" CornerRadius="16"
                        Background="{StaticResource DangerLightBrush}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="IconText" Text="&#x26A0;" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TitleText" Text="{Binding WindowTitle}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 消息内容 -->
            <TextBlock Grid.Row="1" x:Name="MessageText" Text="{Binding Message}"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" VerticalAlignment="Center"
                       LineHeight="22" Margin="44,0,0,16"/>

            <!-- 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消"
                        Style="{StaticResource BtnSecondary}"
                        Padding="18,9" Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton" Content="确认"
                        Style="{StaticResource BtnDanger}"
                        Padding="18,9"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
