<UserControl x:Class="EapWorkAssistant.Views.KnowledgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             FontFamily="{StaticResource DefaultFont}">
    <Grid>
        <!-- 内层内容区域（带边距） -->
        <Grid Margin="28,24">

        <!-- ===== 主区域 ===== -->
        <DockPanel>

            <!-- 顶部栏 -->
            <Border DockPanel.Dock="Top" Background="White" CornerRadius="14" Padding="24"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="知识库" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="构建您的 EAP、SECS/GEM、MES 知识库"
                                   Foreground="{StaticResource TextTertiaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="4,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#x1F50D;" FontSize="13" VerticalAlignment="Center"
                                           Margin="8,0,6,0" Opacity="0.45"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchKeyword}" Width="180" BorderThickness="0"
                                         Background="Transparent" VerticalContentAlignment="Center"
                                         Padding="4,7" FontSize="13"
                                         FontFamily="{StaticResource DefaultFont}"/>
                            </Grid>
                        </Border>
                        <Button Content="搜索" Command="{Binding SearchCommand}"
                                Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Padding="16,9"/>
                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="14,0"/>
                        <Button x:Name="OpenFormBtn" Click="OpenForm_Click"
                                Style="{StaticResource BtnPrimary}" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="新增知识" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 知识列表 -->
            <Border Background="White" CornerRadius="14"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="0"
                    ClipToBounds="True">
                <Grid>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                             Style="{StaticResource ModernListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModernListBoxItem}" Padding="18,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                                   Margin="0,6,0,0" MaxHeight="34"
                                                   ToolTip="{Binding Content}"/>
                                        <Grid Margin="0,10,0,0">
                                            <Border Style="{StaticResource TagPrimary}">
                                                <TextBlock Text="{Binding Tags}" FontSize="11"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           FontWeight="Medium"/>
                                            </Border>
                                            <TextBlock Text="{Binding CreateTime}"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 空状态 -->
                    <Border Visibility="{Binding Items.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                            Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Background="White" CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F4DA;" FontSize="48" HorizontalAlignment="Center" Opacity="0.25"/>
                            <TextBlock Text="暂无知识条目" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                            <TextBlock Text="点击右上角「新增知识」按钮开始构建您的知识库" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
        </Grid>
        <!-- 关闭内层 Margin Grid -->

        <!-- ===== 遮罩层（浮窗打开时显示，覆盖整个视图） ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（从右侧滑入覆盖） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="500">
            <DockPanel>
                <!-- 表单标题（固定在顶部） -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="&#x1F4D6; 知识条目" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="创建和管理您的专业知识文章" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button x:Name="CloseFormBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Click="CloseForm_Click" Style="{StaticResource BtnGhost}"
                                Padding="8,6" ToolTip="关闭面板">
                            <TextBlock Text="&#x2715;" FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮（固定在底部） -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                    <Grid>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="26,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="新建" Command="{Binding NewCommand}"
                                    Style="{StaticResource BtnSecondary}" Padding="18,10"/>
                            <Button Content="删除" Command="{Binding DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem}"
                                    Style="{StaticResource BtnDanger}" Margin="8,0,0,0"
                                    Padding="18,10"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{StaticResource SuccessLightBrush}" CornerRadius="10"
                            Padding="14,10" Margin="0,10,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                                   FontSize="13" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <!-- 表单字段区域 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="标题 *" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Title}" Style="{StaticResource Input}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="标签 *" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Tags}" Style="{StaticResource Input}"
                                 Margin="0,0,0,6"/>
                        <TextBlock Text="多个标签用逗号分隔，如：SECS/GEM, 通信协议" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,18"/>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,2,0,18"/>

                        <TextBlock Text="内容 *" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentItem.Content}" Height="280" Style="{StaticResource TextArea}"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
