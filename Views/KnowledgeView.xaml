<UserControl x:Class="EapWorkAssistant.Views.KnowledgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             FontFamily="{StaticResource DefaultFont}">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClosePanelCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <!-- 内层内容区域（带边距） -->
        <Grid Margin="28,24">

        <!-- ===== 主区域 ===== -->
        <DockPanel>

            <!-- 顶部栏 -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="知识库" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="构建您的 EAP、SECS/GEM、MES 知识库"
                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- 收藏筛选 -->
                        <ToggleButton IsChecked="{Binding ShowFavoritesOnly}" Cursor="Hand"
                                      Style="{StaticResource BtnGhost}" Padding="8,6" Margin="0,0,6,0">
                            <ToggleButton.ToolTip>
                                <ToolTip Style="{StaticResource ModernToolTip}" Content="只看收藏"/>
                            </ToggleButton.ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconStar}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowFavoritesOnly}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="收藏" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowFavoritesOnly}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <!-- 分类筛选 -->
                        <ComboBox ItemsSource="{Binding FilterCategories}"
                                  SelectedItem="{Binding FilterCategory, Mode=TwoWay}"
                                  Style="{StaticResource Select}" Width="120" FontSize="12" Margin="0,0,8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="全部分类"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="4,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSearch}" Fill="{DynamicResource TextSecondaryBrush}"
                                      Width="13" Height="13" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="8,0,6,0" Opacity="0.45"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Style="{StaticResource SearchInput}"/>
                            </Grid>
                        </Border>
                        <Button Content="搜索" Command="{Binding SearchCommand}"
                                Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Padding="16,9"/>
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="14,0"/>
                        <Button x:Name="OpenFormBtn" Click="OpenForm_Click"
                                Style="{StaticResource BtnPrimary}" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="新增知识" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 知识列表 -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0"
                    ClipToBounds="True">
                <Grid>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                             Style="{StaticResource ModernListBox}"
                             ItemContainerStyle="{StaticResource ModernListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="18,14">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="1">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </StackPanel>
                                            <!-- 收藏按钮（悬停时显示） -->
                                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource BtnGhost}" Padding="4,2" FontSize="12"
                                                    Opacity="0.6">
                                                <Button.ToolTip>
                                                    <ToolTip Style="{StaticResource ModernToolTip}" Content="切换收藏"/>
                                                </Button.ToolTip>
                                                <Path Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Data" Value="{StaticResource IconStarOutline}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="1">
                                                                    <Setter Property="Data" Value="{StaticResource IconStar}"/>
                                                                    <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="{Binding Content}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                                   Margin="0,6,0,0" MaxHeight="34">
                                            <TextBlock.ToolTip>
                                                <ToolTip Style="{StaticResource ModernToolTip}" Content="{Binding Content}"/>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <Grid Margin="0,10,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource TagPrimary}" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding Tags}" FontSize="11"
                                                               Foreground="{DynamicResource PrimaryBrush}"
                                                               FontWeight="Medium"/>
                                                </Border>
                                                <Border CornerRadius="6" Padding="8,2" Margin="0,0,6,0"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding Category}" FontSize="10.5"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Category}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CreateTime}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 空状态 -->
                    <Border Visibility="{Binding Items.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                            Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Background="{DynamicResource CardBrush}" CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconBook}" Fill="{DynamicResource TextPrimaryBrush}"
                                  Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                            <TextBlock Text="暂无知识条目" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                            <TextBlock Text="点击右上角「新增知识」按钮开始构建您的知识库" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
        </Grid>
        <!-- 关闭内层 Margin Grid -->

        <!-- ===== 遮罩层（浮窗打开时显示，覆盖整个视图） ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（从右侧滑入覆盖） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="500">
            <DockPanel>
                <!-- 表单标题（固定在顶部） -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource TextPrimaryBrush}"
                                      Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="知识条目" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="创建和管理您的专业知识文章" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button x:Name="CloseFormBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Click="CloseForm_Click" Style="{StaticResource BtnGhost}"
                                Padding="8,6">
                            <Button.ToolTip>
                                <ToolTip Style="{StaticResource ModernToolTip}" Content="关闭面板"/>
                            </Button.ToolTip>
                            <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}"
                                  Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮（固定在底部） -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                    <Grid>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="26,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="新建" Command="{Binding NewCommand}"
                                    Style="{StaticResource BtnSecondary}" Padding="18,10"/>
                            <Button Content="删除" Command="{Binding DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem}"
                                    Style="{StaticResource BtnDanger}" Margin="8,0,0,0"
                                    Padding="18,10"/>
                        </StackPanel>
                    </Grid>
                    <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="10"
                            Padding="14,10" Margin="0,10,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="13" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <!-- 表单字段区域 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="标题 *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TitleBox" Text="{Binding CurrentItem.Title}" Style="{StaticResource Input}"
                                 Margin="0,0,0,14" TextChanged="FormField_Changed"/>

                        <!-- 分类 + 收藏 -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="分类" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding CurrentItem.Category, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}"
                                         Tag="输入或选择分类"
                                         TextChanged="FormField_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <CheckBox IsChecked="{Binding CurrentItem.IsFavorite, Converter={x:Static local:BoolToIntConverter.Instance}}"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Checked="FormField_Changed" Unchecked="FormField_Changed">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                              Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="收藏" FontSize="12"/>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="标签 *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TagsBox" Text="{Binding CurrentItem.Tags}" Style="{StaticResource Input}"
                                 Margin="0,0,0,6" TextChanged="FormField_Changed"/>
                        <TextBlock Text="多个标签用逗号分隔，如：SECS/GEM, 通信协议" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>

                        <!-- 常用标签建议 -->
                        <ItemsControl ItemsSource="{Binding AllTags}" Margin="0,0,0,14">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Style="{StaticResource BtnGhost}"
                                            Padding="8,3" Margin="0,0,5,4" FontSize="11"
                                            Click="TagSuggestion_Click"
                                            Foreground="{DynamicResource PrimaryBrush}" Opacity="0.7"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,18"/>

                        <TextBlock Text="内容 *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="ContentBox" Text="{Binding CurrentItem.Content}" Height="280" Style="{StaticResource TextArea}"
                                 VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
