<UserControl x:Class="EapWorkAssistant.Views.KnowledgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             FontFamily="{StaticResource DefaultFont}">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClosePanelCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <!-- 内层内容区域（带边距） -->
        <Grid Margin="28,24">

        <!-- ===== 主区域 ===== -->
        <DockPanel>

            <!-- 顶部栏 -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource CardBrush}" CornerRadius="16" Padding="24,22"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,16">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="知识库" Style="{StaticResource Heading2}"/>
                            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="10" Padding="10,3"
                                    Margin="10,0,0,0" VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontWeight="Medium" VerticalAlignment="Center">
                                    <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                    <Run Text=" 条"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="构建您的 EAP、SECS/GEM、MES 知识库"
                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- 收藏筛选 -->
                        <ToggleButton IsChecked="{Binding ShowFavoritesOnly}" Cursor="Hand"
                                      Style="{StaticResource BtnGhost}" Padding="10,6" Margin="0,0,8,0">
                            <ToggleButton.ToolTip>
                                <ToolTip Content="只看收藏"/>
                            </ToggleButton.ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconStar}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowFavoritesOnly}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="收藏" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowFavoritesOnly}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <!-- 分类筛选 -->
                        <ComboBox ItemsSource="{Binding FilterCategories}"
                                  SelectedItem="{Binding FilterCategory, Mode=TwoWay}"
                                  Style="{StaticResource Select}" Width="132" FontSize="12" Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="">
                                                        <Setter Property="Text" Value="全部分类"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSearch}" Fill="{DynamicResource TextSecondaryBrush}"
                                      Width="13" Height="13" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="8,0,6,0" Opacity="0.45"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="220"
                                         Style="{StaticResource SearchInput}"/>
                            </Grid>
                        </Border>
                        <Button Content="搜索" Command="{Binding SearchCommand}"
                                Style="{StaticResource BtnPrimary}" Margin="10,0,0,0" Padding="18,9"/>
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="16,0"/>
                        <Button x:Name="OpenFormBtn" Click="OpenForm_Click"
                                Style="{StaticResource BtnPrimary}" Padding="18,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="新增知识" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 知识列表 -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0"
                    ClipToBounds="True">
                <Grid>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                             Style="{StaticResource ModernListBox}"
                             local:ListBoxCopyHelper.EnableCopy="False"
                             ItemContainerStyle="{StaticResource ModernListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="20,16">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380"
                                                           ToolTip="{Binding Title}"/>
                                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                                      Width="12" Height="12" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="1">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </StackPanel>
                                            <!-- 操作按钮（悬停时显示） -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <!-- 编辑按钮 -->
                                                <Button Click="EditItem_Click"
                                                        Style="{StaticResource BtnGhost}" Padding="4,2"
                                                        Opacity="0.6" Margin="0,0,4,0">
                                                    <Path Width="14" Height="14" Stretch="Uniform"
                                                          Fill="{DynamicResource TextSecondaryBrush}"
                                                          Data="M3,17.25V21h3.75L17.81,9.94l-3.75,-3.75L3,17.25z M20.71,7.04c0.39,-0.39 0.39,-1.02 0,-1.41l-2.34,-2.34c-0.39,-0.39 -1.02,-0.39 -1.41,0l-1.83,1.83 3.75,3.75 1.83,-1.83z"/>
                                                </Button>
                                                <!-- 收藏按钮 -->
                                                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource BtnGhost}" Padding="4,2" FontSize="12"
                                                        Opacity="0.6">
                                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Data" Value="{StaticResource IconStarOutline}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="1">
                                                                        <Setter Property="Data" Value="{StaticResource IconStar}"/>
                                                                        <Setter Property="Fill" Value="{DynamicResource WarningBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding Content}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"
                                                   Margin="0,6,0,0" MaxHeight="34"
                                                   ToolTip="{Binding Content}"/>
                                        <Grid Margin="0,12,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <ItemsControl ItemsSource="{Binding Tags, Converter={x:Static local:TagsSplitConverter.Instance}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource TagPrimary}" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding}" FontSize="11"
                                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                                           FontWeight="Medium"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border CornerRadius="6" Padding="8,2" Margin="0,0,6,0"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding Category}" FontSize="10.5"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Category}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CreateTime}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       FontSize="11" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 空状态 -->
                    <Border Visibility="{Binding Items.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                            Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            Background="{DynamicResource CardBrush}" CornerRadius="16">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconBook}" Fill="{DynamicResource TextPrimaryBrush}"
                                  Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                            <TextBlock Text="暂无知识条目" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                            <TextBlock Text="点击右上角「新增知识」按钮开始构建您的知识库" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
        </Grid>
        <!-- 关闭内层 Margin Grid -->

        <!-- ===== 遮罩层（浮窗打开时显示，覆盖整个视图） ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（从右侧滑入覆盖） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="520">
            <DockPanel>

                <!-- ── 面板头部 ── -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource PrimaryLightBrush}"
                                    CornerRadius="8" Width="32" Height="32" Margin="0,0,12,0">
                                <Path Data="{StaticResource IconBook}" Fill="{DynamicResource PrimaryBrush}"
                                      Width="15" Height="15" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="知识条目" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="创建和管理您的专业知识文章" FontSize="11.5"
                                           Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="CloseForm_Click" Style="{StaticResource BtnGhost}" Padding="8,6">
                            <Button.ToolTip>
                                <ToolTip Content="关闭面板 (Esc)"/>
                            </Button.ToolTip>
                            <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}"
                                  Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14,0,0" Opacity="0.5"/>
                </StackPanel>

                <!-- ── 底部操作栏 ── -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" Opacity="0.5"/>

                    <!-- 操作按钮 -->
                    <Grid>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="32,10" FontSize="13"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="新建" Command="{Binding NewCommand}"
                                    Style="{StaticResource BtnSecondary}" Padding="20,10">
                                <Button.Visibility>
                                    <Binding Path="CurrentItem.Id">
                                        <Binding.Converter>
                                            <local:IdToVisibilityConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </Button.Visibility>
                            </Button>
                            <Button Content="删除" Command="{Binding DeleteCommand}"
                                    CommandParameter="{Binding SelectedItem}"
                                    Style="{StaticResource BtnDanger}" Margin="8,0,0,0"
                                    Padding="20,10"/>
                        </StackPanel>
                    </Grid>

                    <!-- 状态消息 -->
                    <Border CornerRadius="8" Padding="12,8" Margin="0,10,0,0"
                            Background="{DynamicResource SuccessLightBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SuccessBrush}"
                                       FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── 表单字段区域（滚动） ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,16,0,16">

                        <!-- ═══ 基本信息 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="基本信息" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- 标题 -->
                                <TextBlock Text="标题" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TitleBox" Text="{Binding CurrentItem.Title}"
                                         Style="{StaticResource Input}"
                                         Margin="0,0,0,16" TextChanged="FormField_Changed"/>

                                <!-- 分类（下拉建议） + 收藏 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="分类" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <ComboBox SelectedItem="{Binding CurrentItem.Category, Mode=TwoWay}"
                                                  ItemsSource="{Binding AllCategories}"
                                                  IsEditable="False"
                                                  Style="{StaticResource Select}"
                                                  FontSize="13"
                                                  SelectionChanged="FormField_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding CurrentItem.IsFavorite, Converter={x:Static local:BoolToIntConverter.Instance}}"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  Checked="FormField_Changed" Unchecked="FormField_Changed"
                                                  Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                                      Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="收藏" FontSize="12.5" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 标签管理 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="标签管理" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,14"/>

                                <TextBox x:Name="TagsBox" Text="{Binding CurrentItem.Tags}"
                                         Style="{StaticResource Input}"
                                         Margin="0,0,0,6" TextChanged="FormField_Changed"/>
                                <TextBlock Text="多个标签用逗号分隔，如：SECS/GEM, 通信协议"
                                           FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                           Margin="0,0,0,12"/>

                                <!-- 常用标签快捷添加 -->
                                <StackPanel>
                                    <TextBlock Text="常用标签" FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               Margin="0,0,0,8" FontWeight="Medium"/>
                                    <ItemsControl ItemsSource="{Binding AllTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}"
                                                        Style="{StaticResource BtnGhost}"
                                                        Padding="10,4" Margin="0,0,6,6" FontSize="11"
                                                        Click="TagSuggestion_Click" Cursor="Hand"
                                                        Foreground="{DynamicResource PrimaryBrush}" Opacity="0.7">
                                                    <Button.ToolTip>
                                                        <ToolTip Content="点击添加此标签"/>
                                                    </Button.ToolTip>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 知识内容 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="知识内容" FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="支持多行文本编辑"
                                               FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBox x:Name="ContentBox" Text="{Binding CurrentItem.Content}"
                                         Height="260" Style="{StaticResource TextArea}"
                                         VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
