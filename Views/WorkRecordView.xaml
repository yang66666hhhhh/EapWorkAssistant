<UserControl x:Class="EapWorkAssistant.Views.WorkRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             xmlns:views="clr-namespace:EapWorkAssistant.Views"
             FontFamily="{StaticResource DefaultFont}">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveRecordCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClosePanelCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewRecordCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <!-- 内层内容区域 -->
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== Tab 切换栏 ===== -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="当日记录" Click="TabDaily_Click" Padding="16,8" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="全部记录" Click="TabAll_Click" Padding="16,8" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Margin="6,0,0,0" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- ===== Tab 0: 当日记录 ===== -->
            <Border Grid.Row="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 顶部栏 ===== -->
            <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14" ClipToBounds="True">
                <StackPanel>
                    <!-- 标题行 -->
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="工作记录" Style="{StaticResource Heading2}"/>
                            <TextBlock Text="记录每日工作内容、成果和问题"
                                       Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button x:Name="OpenFormBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="OpenForm_Click" Style="{StaticResource BtnPrimary}" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="新增记录" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                        <!-- 工具栏 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <!-- 日期显示 -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Padding="10,0" Height="34" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource TextSecondaryBrush}"
                                              Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                                        <TextBlock x:Name="DateDisplayText" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="CalendarToggleBtn" Content="选择日期" Click="CalendarToggle_Click"
                                        Style="{StaticResource BtnSecondary}" Margin="6,0,0,0" Padding="10,7" FontSize="12"/>

                                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="10,5" Opacity="0.5"/>

                                <!-- 报告按钮组 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="日报" Command="{Binding GenerateDailyReportCommand}"
                                            Style="{StaticResource BtnPrimary}" Padding="10,7" FontSize="12"/>
                                    <Button Content="周报" Command="{Binding GenerateWeeklyReportCommand}"
                                            Style="{StaticResource BtnSuccess}" Margin="5,0,0,0" Padding="10,7" FontSize="12"/>
                                    <Button Content="月报" Command="{Binding GenerateMonthlyReportCommand}"
                                            Style="{StaticResource BtnWarning}" Margin="5,0,0,0" Padding="10,7" FontSize="12"/>
                                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="8,5" Opacity="0.5"/>
                                    <Button Content="导出CSV" Command="{Binding ExportCsvCommand}"
                                            Style="{StaticResource BtnGhost}" Padding="10,7" FontSize="12"
                                            Foreground="{DynamicResource PrimaryBrush}"/>
                                    <Button Content="导入CSV" Command="{Binding ImportCsvCommand}"
                                            Style="{StaticResource BtnGhost}" Padding="10,7" FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
            </Border>

            <!-- ===== 数据统计条（带左侧色带） ===== -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 今日工时 -->
                <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="11"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="今日工时" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding TodayHours, StringFormat={}{0:F1}}" FontSize="22"
                                               FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text="h" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconClock}" Fill="{DynamicResource PrimaryBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 记录数 -->
                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="11"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource SuccessBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="记录数" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding RecordCount}" FontSize="22"
                                               FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                    <TextBlock Text="条" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconList}" Fill="{DynamicResource SuccessBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 亮点标记 -->
                <Border Grid.Column="4" Background="{DynamicResource CardBrush}" CornerRadius="11"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource WarningBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="亮点标记" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding HighlightCount}" FontSize="22"
                                               FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                    <TextBlock Text="项" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== 数据表格 + 报告预览 ===== -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- 表格 -->
                <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0"
                        ClipToBounds="True">
                    <Grid>
                        <DataGrid ItemsSource="{Binding Records}" Style="{StaticResource ModernGrid}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  ClipboardCopyMode="IncludeHeader">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernGridColumnHeader}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernGridCell}"/>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernGridRow}"/>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="38"
                                                        CellTemplate="{StaticResource HighlightStarCell}">
                                    <DataGridTemplateColumn.Header>
                                        <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                              Width="13" Height="13" Stretch="Uniform"/>
                                    </DataGridTemplateColumn.Header>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="任务" Binding="{Binding ProjectName}" Width="160"/>
                                <!-- 类型 - 彩色标签 -->
                                <DataGridTemplateColumn Header="类型" Width="100"
                                                        ClipboardContentBinding="{Binding WorkType}"
                                                        CellTemplate="{StaticResource WorkTypeBadgeCell}"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Content}" Width="300" MinWidth="240">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}">
                                            <Setter Property="ToolTip" Value="{Binding Content}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="工作成果" Binding="{Binding Achievement}" Width="240" MinWidth="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}">
                                            <Setter Property="ToolTip" Value="{Binding Achievement}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="工时" Binding="{Binding Hours, StringFormat={}{0:F1}h}" Width="80"/>
                                <!-- 进度 - 进度条 -->
                                <DataGridTemplateColumn Header="进度" Width="144"
                                                        ClipboardContentBinding="{Binding Progress, StringFormat={}{0}%}"
                                                        CellTemplate="{StaticResource ProgressBarCell}"/>
                                <DataGridTextColumn Header="问题" Binding="{Binding Problem}" Width="240" MinWidth="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}">
                                            <Setter Property="ToolTip" Value="{Binding Problem}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="操作" Width="136">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="编辑"
                                                        Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Click="EditRow_Click"
                                                        Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"/>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"
                                                        Foreground="{DynamicResource DangerBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 空状态 -->
                        <Border Visibility="{Binding Records.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                                Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                Background="{DynamicResource CardBrush}" CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconPencil}" Fill="{DynamicResource TextPrimaryBrush}"
                                      Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                <TextBlock Text="当日暂无工作记录" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                                <TextBlock Text="点击上方按钮开始记录" FontSize="12"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 拖拽分隔条 -->
                <GridSplitter Grid.Row="1" Style="{StaticResource DragSplitter}"/>

                <!-- 报告预览 -->
                <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="14" Margin="0,0,0,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,10,16,8">
                            <Path Data="{StaticResource IconTrend}" Fill="{DynamicResource TextSecondaryBrush}"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                            <TextBlock Text="报告预览" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="10,0" Opacity="0.5"/>
                            <Button Content="复制" Command="{Binding CopyReportCommand}"
                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                    Foreground="{DynamicResource SuccessBrush}"/>
                            <Button Content="保存" Command="{Binding SaveReportCommand}"
                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                    Foreground="{DynamicResource WarningBrush}"/>
                            <Button Content="Markdown" Command="{Binding SaveReportAsMarkdownCommand}"
                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                    Foreground="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="9"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="10,0,10,10" Padding="12">
                            <TextBox x:Name="ReportTextBox" Text="{Binding ReportText}" IsReadOnly="True" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0" Background="Transparent"
                                     FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
            </Grid>
            </Border>

            <!-- ===== Tab 1: 全部记录 ===== -->
            <Border Grid.Row="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 筛选栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBrush}" CornerRadius="14"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,10" ClipToBounds="True" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource PrimaryGradient}" CornerRadius="13,0,0,13"/>
                            <StackPanel Grid.Column="1" Margin="18,12,18,12">
                                <!-- 标题行 -->
                                <Grid Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="全部记录" Style="{StaticResource Heading2}"/>
                                        <TextBlock Text="查看和筛选所有工作记录"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Content="导出CSV" Command="{Binding ExportAllCsvCommand}"
                                            Style="{StaticResource BtnGhost}" Padding="10,7" FontSize="12"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,10" Opacity="0.7"/>
                                <!-- 筛选条件 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 日期快捷 -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="本周" Command="{Binding SetDatePresetCommand}" CommandParameter="thisWeek"
                                                Padding="10,6" FontSize="12" Margin="0,0,5,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="thisWeek">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="本月" Command="{Binding SetDatePresetCommand}" CommandParameter="thisMonth"
                                                Padding="10,6" FontSize="12" Margin="0,0,5,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="thisMonth">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="近3月" Command="{Binding SetDatePresetCommand}" CommandParameter="last3Months"
                                                Padding="10,6" FontSize="12" Margin="0,0,5,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="last3Months">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="全部" Command="{Binding SetDatePresetCommand}" CommandParameter="all"
                                                Padding="10,6" FontSize="12">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="thisWeek">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="thisMonth">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ActiveDatePreset}" Value="last3Months">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                    <!-- 开始日期 -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="从" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Button x:Name="FilterStartBtn" Click="FilterStart_Click"
                                                Style="{StaticResource BtnSecondary}" Padding="10,6" FontSize="12">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource TextSecondaryBrush}"
                                                      Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7"/>
                                                <TextBlock x:Name="FilterStartText" Text="开始日期" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <!-- 结束日期 -->
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="至" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Button x:Name="FilterEndBtn" Click="FilterEnd_Click"
                                                Style="{StaticResource BtnSecondary}" Padding="10,6" FontSize="12">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource TextSecondaryBrush}"
                                                      Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7"/>
                                                <TextBlock x:Name="FilterEndText" Text="结束日期" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <!-- 项目筛选 -->
                                    <ComboBox Grid.Column="8" ItemsSource="{Binding FilterProjects}"
                                              SelectedItem="{Binding FilterProject, Mode=TwoWay}"
                                              Style="{StaticResource Select}" Width="120" FontSize="12">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="">
                                                                    <Setter Property="Text" Value="全部项目"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!-- 类型筛选 -->
                                    <ComboBox Grid.Column="10" ItemsSource="{Binding FilterWorkTypes}"
                                              SelectedItem="{Binding FilterWorkType, Mode=TwoWay}"
                                              Style="{StaticResource Select}" Width="120" FontSize="12">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="">
                                                                    <Setter Property="Text" Value="全部类型"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 搜索栏 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="11"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Margin="0,0,0,10" Padding="14,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconSearch}" Fill="{DynamicResource TextSecondaryBrush}"
                                      Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.6"/>
                                <TextBox Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource SearchInput}" Width="320"
                                         FontSize="12.5" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Run Text="共 "/><Run Text="{Binding FilteredTotalCount, Mode=OneWay}"/><Run Text=" 条"/>
                                </TextBlock>
                                <Button Content="清空" Command="{Binding ClearSearchCommand}"
                                        Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                        Foreground="{DynamicResource PrimaryBrush}">
                                    <Button.Visibility>
                                        <Binding Path="SearchKeyword" Converter="{x:Static local:StringToVisibilityConverter.Instance}"/>
                                    </Button.Visibility>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 统计条 -->
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="11"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="11,0,0,11"/>
                                <Grid Grid.Column="1" Margin="14,10">
                                    <StackPanel>
                                        <TextBlock Text="筛选工时" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding AllTotalHours, StringFormat={}{0:F1}}" FontSize="22"
                                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                            <TextBlock Text="h" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="11"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource SuccessBrush}" CornerRadius="11,0,0,11"/>
                                <Grid Grid.Column="1" Margin="14,10">
                                    <StackPanel>
                                        <TextBlock Text="记录数" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding AllTotalCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Text="条" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="4" Background="{DynamicResource CardBrush}" CornerRadius="11"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource WarningBrush}" CornerRadius="11,0,0,11"/>
                                <Grid Grid.Column="1" Margin="14,10">
                                    <StackPanel>
                                        <TextBlock Text="亮点标记" FontSize="10.5" Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding AllHighlightCount}" FontSize="22"
                                                       FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                            <TextBlock Text="项" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 记录列表 + 分页 -->
                    <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="14"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="0" ClipToBounds="True">
                        <DockPanel>
                            <!-- 分页控件 -->
                            <Border DockPanel.Dock="Bottom" Padding="16,10"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilteredTotalCount}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：每页条数选择 -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="每页" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox ItemsSource="{Binding PageSizeOptions}"
                                                  SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                                  Style="{StaticResource Select}" Width="68" FontSize="12"/>
                                        <TextBlock Text="条" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- 中间：翻页按钮 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <!-- 首页 -->
                                        <Button Command="{Binding FirstPageCommand}"
                                                Style="{StaticResource PageNavButton}">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource ModernToolTip}" Content="首页"/>
                                            </Button.ToolTip>
                                            <Path Data="{StaticResource IconSkipFirst}" Fill="{DynamicResource TextSecondaryBrush}"
                                                  Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <!-- 上一页 -->
                                        <Button Command="{Binding PrevPageCommand}"
                                                Style="{StaticResource PageNavButton}">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource ModernToolTip}" Content="上一页"/>
                                            </Button.ToolTip>
                                            <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextSecondaryBrush}"
                                                  Width="16" Height="16" Stretch="Uniform"/>
                                        </Button>

                                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,6" Opacity="0.5"/>

                                        <!-- 页码按钮 -->
                                        <ItemsControl ItemsSource="{Binding VisiblePageNumbers}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}"
                                                            Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="1,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PageNumberButton}">
                                                                <Style.Triggers>
                                                                    <!-- 省略号（值为0）禁用点击 -->
                                                                    <DataTrigger Binding="{Binding}" Value="0">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Setter Property="Content" Value="..."/>
                                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource TextTertiaryBrush}"/>
                                                                    </DataTrigger>
                                                                    <!-- 当前页高亮 -->
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding>
                                                                                <MultiBinding.Converter>
                                                                                    <local:PageActiveConverter/>
                                                                                </MultiBinding.Converter>
                                                                                <Binding/>
                                                                                <Binding Path="DataContext.CurrentPage"
                                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border CornerRadius="8"
                                                                                            Background="{DynamicResource PrimaryBrush}"
                                                                                            Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                                          VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,6" Opacity="0.5"/>

                                        <!-- 下一页 -->
                                        <Button Command="{Binding NextPageCommand}"
                                                Style="{StaticResource PageNavButton}">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource ModernToolTip}" Content="下一页"/>
                                            </Button.ToolTip>
                                            <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextSecondaryBrush}"
                                                  Width="16" Height="16" Stretch="Uniform"/>
                                        </Button>
                                        <!-- 末页 -->
                                        <Button Command="{Binding LastPageCommand}"
                                                Style="{StaticResource PageNavButton}">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource ModernToolTip}" Content="末页"/>
                                            </Button.ToolTip>
                                            <Path Data="{StaticResource IconSkipLast}" Fill="{DynamicResource TextSecondaryBrush}"
                                                  Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- 右侧：总记录数 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="共 "/><Run Text="{Binding FilteredTotalCount, Mode=OneWay}"
                                                                  FontWeight="SemiBold"
                                                                  Foreground="{DynamicResource TextSecondaryBrush}"/><Run Text=" 条"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Grid>
                            <DataGrid ItemsSource="{Binding AllRecords}" Style="{StaticResource ModernGrid}"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                      ClipboardCopyMode="IncludeHeader">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernGridColumnHeader}"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernGridCell}"/>
                                </DataGrid.CellStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernGridRow}"/>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="日期" Binding="{Binding WorkDate}" Width="136"/>
                                    <DataGridTemplateColumn Width="38"
                                                            CellTemplate="{StaticResource HighlightStarCell}">
                                        <DataGridTemplateColumn.Header>
                                            <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                                  Width="13" Height="13" Stretch="Uniform"/>
                                        </DataGridTemplateColumn.Header>
                                    </DataGridTemplateColumn>
                                    <!-- 任务（带搜索高亮） -->
                                    <DataGridTemplateColumn Header="任务" Width="160" ClipboardContentBinding="{Binding ProjectName}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock local:Highlight.Text="{Binding ProjectName}"
                                                           local:Highlight.Keyword="{Binding DataContext.SearchKeyword, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding ProjectName}"
                                                           VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="类型" Width="100"
                                                            CellTemplate="{StaticResource WorkTypeBadgeCell}"/>
                                    <!-- 内容（带搜索高亮） -->
                                    <DataGridTemplateColumn Header="内容" Width="300" MinWidth="240" ClipboardContentBinding="{Binding Content}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock local:Highlight.Text="{Binding Content}"
                                                           local:Highlight.Keyword="{Binding DataContext.SearchKeyword, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                           ToolTip="{Binding Content}"
                                                           VerticalAlignment="Center"/>

                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <!-- 工作成果（带搜索高亮） -->
                                    <DataGridTemplateColumn Header="工作成果" Width="240" MinWidth="220" ClipboardContentBinding="{Binding Achievement}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock local:Highlight.Text="{Binding Achievement}"
                                                           local:Highlight.Keyword="{Binding DataContext.SearchKeyword, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                           ToolTip="{Binding Achievement}"
                                                           VerticalAlignment="Center"/>

                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="工时" Binding="{Binding Hours, StringFormat={}{0:F1}h}" Width="80"/>
                                    <DataGridTemplateColumn Header="进度" Width="144"
                                                            ClipboardContentBinding="{Binding Progress, StringFormat={}{0}%}"
                                                            CellTemplate="{StaticResource ProgressBarCell}"/>
                                    <!-- 问题（带搜索高亮） -->
                                    <DataGridTemplateColumn Header="问题" Width="240" MinWidth="220" ClipboardContentBinding="{Binding Problem}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock local:Highlight.Text="{Binding Problem}"
                                                           local:Highlight.Keyword="{Binding DataContext.SearchKeyword, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                           ToolTip="{Binding Problem}"
                                                           VerticalAlignment="Center"/>

                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="操作" Width="136">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="编辑"
                                                            Command="{Binding DataContext.EditAllRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Click="EditRow_Click"
                                                            Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"/>
                                                    <Button Content="删除"
                                                            Command="{Binding DataContext.DeleteAllRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"
                                                            Foreground="{DynamicResource DangerBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <!-- 空状态 -->
                            <Border Visibility="{Binding AllRecords.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                                    Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Background="{DynamicResource CardBrush}" CornerRadius="14">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconSearch}" Fill="{DynamicResource TextPrimaryBrush}"
                                          Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                    <TextBlock Text="暂无匹配的工作记录" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                                    <TextBlock Text="尝试调整筛选条件" FontSize="12"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== 共享日历浮窗（当日记录 + 全部记录筛选共用） ===== -->
        <Border x:Name="CalendarBackdrop" Style="{StaticResource CalendarOverlay}"
                MouseLeftButtonDown="CalendarBackdrop_Click"
                Panel.ZIndex="50"/>
        <Border x:Name="CalendarContainer" Style="{StaticResource FloatingPanel}"
                Margin="20,90,0,0" Panel.ZIndex="51"
                Width="310">
            <views:CustomCalendar x:Name="SharedCal"
                                  SelectedDate="{Binding SelectedDate, Mode=TwoWay}"/>
        </Border>

        <!-- ===== 遮罩层 ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（右侧滑入） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="520">
            <DockPanel>

                <!-- ── 面板头部 ── -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource PrimaryLightBrush}"
                                    CornerRadius="8" Width="32" Height="32" Margin="0,0,12,0">
                                <Path Data="{StaticResource IconClipboard}" Fill="{DynamicResource PrimaryBrush}"
                                      Width="15" Height="15" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding FormTitle}" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SelectedDate, StringFormat='yyyy-MM-dd ddd'}" FontSize="11.5"
                                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="8,2,8,2"/>
                                    <TextBlock Text="记录每日工作内容与成果" FontSize="11.5"
                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="TemplateBtn" Style="{StaticResource BtnGhost}" Padding="8,6">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource ModernToolTip}" Content="使用模板填充内容"/>
                                </Button.ToolTip>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconList}" Fill="{DynamicResource PrimaryBrush}"
                                              Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="模板" FontSize="12" Foreground="{DynamicResource PrimaryBrush}"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button x:Name="CopyLastBtn" Click="CopyLast_Click"
                                    Style="{StaticResource BtnGhost}" Padding="8,6">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource ModernToolTip}" Content="复制上一条记录的任务和类型"/>
                                </Button.ToolTip>
                                <TextBlock Text="复制上条" FontSize="12"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Button>
                            <Button Click="CloseForm_Click"
                                    Style="{StaticResource BtnGhost}" Padding="8,6" Margin="4,0,0,0">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource ModernToolTip}" Content="关闭面板 (Esc)"/>
                                </Button.ToolTip>
                                <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,14,0,0" Opacity="0.5"/>
                </StackPanel>

                <!-- ── 底部操作栏 ── -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" Opacity="0.5"/>

                    <!-- 操作按钮 -->
                    <Grid>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveRecordCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="32,10" FontSize="13"/>
                        <Button Content="新建" Command="{Binding NewRecordCommand}"
                                Style="{StaticResource BtnSecondary}" HorizontalAlignment="Right"
                                Padding="20,10">
                            <Button.Visibility>
                                <Binding Path="CurrentRecord.Id">
                                    <Binding.Converter>
                                        <local:IdToVisibilityConverter/>
                                    </Binding.Converter>
                                </Binding>
                            </Button.Visibility>
                        </Button>
                    </Grid>

                    <!-- 状态消息 -->
                    <Border CornerRadius="8" Padding="12,8" Margin="0,10,0,0"
                            Background="{DynamicResource SuccessLightBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SuccessBrush}"
                                       FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── 表单字段区域（滚动） ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,16,0,16">

                        <!-- ═══ 基本信息 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="基本信息" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- 任务 + 类型 -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="任务" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding CurrentRecord.ProjectName}"
                                                  Style="{StaticResource Select}" SelectionChanged="FormField_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="类型" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding WorkTypes}" SelectedItem="{Binding CurrentRecord.WorkType}"
                                                  Style="{StaticResource Select}" SelectionChanged="FormField_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 快捷模板 -->
                                <TextBlock Text="快捷模板" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding ContentTemplates}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}" Style="{StaticResource BtnGhost}"
                                                    Padding="10,5" Margin="0,0,6,6" FontSize="12"
                                                    Command="{Binding DataContext.ApplyTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="{DynamicResource PrimaryBrush}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 工作记录 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="工作记录" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- 工作内容 -->
                                <TextBlock Text="工作内容" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding CurrentRecord.Content}" Height="160"
                                         Style="{StaticResource TextArea}" Margin="0,0,0,6"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                                <TextBlock Text="描述做了什么、关键产出和交付物" FontSize="11"
                                           Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>

                                <!-- 工作成果 -->
                                <TextBlock Text="工作成果" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding CurrentRecord.Achievement}" Height="80"
                                         Style="{StaticResource TextArea}" Margin="0,0,0,6"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                                <TextBlock Text="记录本项工作的具体成果和产出（可选，用于转正述职报告）" FontSize="11"
                                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 其他信息 ═══ -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"
                                Padding="18,16">
                            <StackPanel>
                                <TextBlock Text="其他信息" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- 问题与解决方案 -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Padding="14,10" Margin="0,0,0,14" Cursor="Hand">
                                    <StackPanel>
                                        <CheckBox x:Name="ProblemToggle" Content="遇到了问题？点击展开记录"
                                                  IsChecked="{Binding HasProblem, Mode=TwoWay}"
                                                  FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <StackPanel Visibility="{Binding IsChecked, ElementName=ProblemToggle, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                                    Margin="0,10,0,4">
                                            <TextBlock Text="问题描述" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding CurrentRecord.Problem}" Height="64"
                                                     Style="{StaticResource TextArea}" Margin="0,0,0,10"
                                                     VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                                            <TextBlock Text="解决方案" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding CurrentRecord.Solution}" Height="64"
                                                     Style="{StaticResource TextArea}" Margin="0,0,0,4"
                                                     VerticalScrollBarVisibility="Auto" TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 工时与进度 -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="10" Padding="14,10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="工时 (小时)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding CurrentRecord.Hours}" Style="{StaticResource Input}"
                                                     BorderThickness="0" Background="Transparent" Padding="0,4"
                                                     PreviewTextInput="HoursInput_PreviewTextInput"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="10" Padding="14,10"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="进度 (%)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding CurrentRecord.Progress}" Style="{StaticResource Input}"
                                                     BorderThickness="0" Background="Transparent" Padding="0,4"
                                                     PreviewTextInput="ProgressInput_PreviewTextInput"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- 亮点标记 -->
                                <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="10"
                                        Padding="14,12" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <CheckBox x:Name="HighlightToggle"
                                                  IsChecked="{Binding CurrentRecord.IsHighlight, Converter={x:Static local:BoolToIntConverter.Instance}}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Margin="0,0,0,8" Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                                                  Checked="FormField_Changed" Unchecked="FormField_Changed">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource WarningBrush}"
                                                      Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="标记为工作亮点" FontSize="13" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </CheckBox>
                                        <StackPanel Visibility="{Binding IsChecked, ElementName=HighlightToggle, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                            <TextBox Text="{Binding CurrentRecord.HighlightNote, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource TextArea}" Height="56"
                                                     VerticalScrollBarVisibility="Auto"/>
                                            <TextBlock Text="简要描述这项工作的亮点和成果" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
