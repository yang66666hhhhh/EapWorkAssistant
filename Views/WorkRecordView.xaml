<UserControl x:Class="EapWorkAssistant.Views.WorkRecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             xmlns:views="clr-namespace:EapWorkAssistant.Views"
             FontFamily="{StaticResource DefaultFont}">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveRecordCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClosePanelCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <!-- 内层内容区域 -->
        <Grid Margin="20,16">

        <!-- ===== 主区域（Grid 布局，支持 GridSplitter 拖拽） ===== -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== 顶部栏 ===== -->
            <Border Grid.Row="0" Background="White" CornerRadius="13" Padding="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,10" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧渐变装饰条 -->
                    <Border Grid.Column="0" Background="{StaticResource PrimaryGradient}" CornerRadius="13,0,0,13"/>

                    <!-- 内容区 -->
                    <StackPanel Grid.Column="1" Margin="18,14,18,14">
                        <!-- 标题行 -->
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="工作记录" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="记录每日工作内容、成果和问题"
                                           Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="OpenFormBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Click="OpenForm_Click" Style="{StaticResource BtnPrimary}" Padding="14,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Foreground="White"/>
                                    <TextBlock Text="新增记录" FontSize="12.5" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,10" Opacity="0.7"/>

                        <!-- 工具栏 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <!-- 日期显示 -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Padding="10,0" Height="34" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x1F4C5;" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                                        <TextBlock x:Name="DateDisplayText" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="CalendarToggleBtn" Content="选择日期" Click="CalendarToggle_Click"
                                        Style="{StaticResource BtnSecondary}" Margin="6,0,0,0" Padding="10,7" FontSize="12"/>

                                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,5" Opacity="0.5"/>

                                <!-- 报告按钮组 -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="日报" Command="{Binding GenerateDailyReportCommand}"
                                            Style="{StaticResource BtnPrimary}" Padding="10,7" FontSize="12"/>
                                    <Button Content="周报" Command="{Binding GenerateWeeklyReportCommand}"
                                            Style="{StaticResource BtnSuccess}" Margin="5,0,0,0" Padding="10,7" FontSize="12"/>
                                    <Button Content="月报" Command="{Binding GenerateMonthlyReportCommand}"
                                            Style="{StaticResource BtnWarning}" Margin="5,0,0,0" Padding="10,7" FontSize="12"/>
                                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,5" Opacity="0.5"/>
                                    <Button Content="导出CSV" Command="{Binding ExportCsvCommand}"
                                            Style="{StaticResource BtnGhost}" Padding="10,7" FontSize="12"
                                            Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 数据统计条（带左侧色带） ===== -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 今日工时 -->
                <Border Grid.Column="0" Background="White" CornerRadius="11"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="今日工时" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding TodayHours, StringFormat={}{0:F1}}" FontSize="22"
                                               FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="h" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="&#x23F1;" FontSize="13" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 记录数 -->
                <Border Grid.Column="2" Background="White" CornerRadius="11"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource SuccessBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="记录数" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding RecordCount}" FontSize="22"
                                               FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="条" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{StaticResource SuccessLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F4CB;" FontSize="13" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 亮点标记 -->
                <Border Grid.Column="4" Background="White" CornerRadius="11"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True" Padding="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource WarningBrush}" CornerRadius="11,0,0,11"/>
                        <Grid Grid.Column="1" Margin="14,10">
                            <StackPanel>
                                <TextBlock Text="亮点标记" FontSize="10.5" Foreground="{StaticResource TextTertiaryBrush}"
                                           FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding HighlightCount}" FontSize="22"
                                               FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                    <TextBlock Text="项" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{StaticResource WarningLightBrush}" CornerRadius="8"
                                    Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="&#x2B50;" FontSize="13" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== 数据表格 + 报告预览 ===== -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- 表格 -->
                <Border Grid.Row="0" Background="White" CornerRadius="13"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="0"
                        ClipToBounds="True">
                    <Grid>
                        <DataGrid ItemsSource="{Binding Records}" Style="{StaticResource ModernGrid}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernGridColumnHeader}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernGridCell}"/>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernGridRow}"/>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="&#x2B50;" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="&#x2B50;" FontSize="13" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHighlight}" Value="1">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="任务" Binding="{Binding ProjectName}" Width="130"/>
                                <!-- 类型 - 彩色标签 -->
                                <DataGridTemplateColumn Header="类型" Width="80"
                                                        CellTemplate="{StaticResource WorkTypeBadgeCell}"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Content}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="工时" Binding="{Binding Hours, StringFormat={}{0:F1}h}" Width="65"/>
                                <!-- 进度 - 进度条 -->
                                <DataGridTemplateColumn Header="进度" Width="110"
                                                        CellTemplate="{StaticResource ProgressBarCell}"/>
                                <DataGridTemplateColumn Header="操作" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="编辑"
                                                        Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Click="EditRow_Click"
                                                        Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"/>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="12"
                                                        Foreground="{StaticResource DangerBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 空状态 -->
                        <Border Visibility="{Binding Records.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                                Padding="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                Background="White" CornerRadius="13">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F4DD;" FontSize="44" HorizontalAlignment="Center" Opacity="0.2"/>
                                <TextBlock Text="当日暂无工作记录" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Medium"/>
                                <TextBlock Text="点击上方按钮开始记录" FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 拖拽分隔条 -->
                <GridSplitter Grid.Row="1" Height="12" HorizontalAlignment="Stretch"
                              Background="#FFE5E7EB" ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True" Cursor="SizeNS"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" IsHitTestVisible="False">
                    <Ellipse Width="4" Height="4" Fill="#FF9CA3AF" Margin="0,0,4,0"/>
                    <Ellipse Width="4" Height="4" Fill="#FF9CA3AF" Margin="0,0,4,0"/>
                    <Ellipse Width="4" Height="4" Fill="#FF9CA3AF"/>
                </StackPanel>

                <!-- 报告预览 -->
                <Border Grid.Row="2" Background="White" CornerRadius="13" Margin="0,0,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,10,16,8">
                            <TextBlock Text="&#x1F4E4;" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                            <TextBlock Text="报告预览" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,0" Opacity="0.5"/>
                            <Button Content="复制" Command="{Binding CopyReportCommand}"
                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                    Foreground="{StaticResource SuccessBrush}"/>
                            <Button Content="保存" Command="{Binding SaveReportCommand}"
                                    Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="11.5"
                                    Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="9"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="10,0,10,10" Padding="12">
                            <TextBox x:Name="ReportTextBox" Text="{Binding ReportText}" IsReadOnly="True" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0" Background="Transparent"
                                     FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
        </Grid>

        <!-- ===== 日历浮窗（使用覆盖层，避免 Popup 渲染问题） ===== -->
        <Border x:Name="CalendarBackdrop" Style="{StaticResource CalendarOverlay}"
                MouseLeftButtonDown="CalendarBackdrop_Click"
                Panel.ZIndex="50"/>
        <Border x:Name="CalendarContainer" Style="{StaticResource FloatingPanel}"
                Margin="20,90,0,0" Panel.ZIndex="51"
                Width="310">
            <views:CustomCalendar x:Name="CustomCal"
                                  SelectedDate="{Binding SelectedDate, Mode=TwoWay}"/>
        </Border>

        <!-- ===== 遮罩层 ===== -->
        <Border x:Name="Backdrop" Style="{StaticResource OverlayBackdrop}"
                MouseLeftButtonDown="Backdrop_Click"/>

        <!-- ===== 浮窗表单（右侧滑入） ===== -->
        <Border x:Name="FormPanel" Style="{StaticResource SidePanel}" Width="520">
            <DockPanel>
                <!-- 表单标题 -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedDate, StringFormat='yyyy-MM-dd ddd'}" FontSize="12"
                                           Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,2,10,2"/>
                                <TextBlock Text="记录每日工作内容与成果" FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button x:Name="TemplateBtn" Style="{StaticResource BtnGhost}" Padding="8,6"
                                    ToolTip="使用模板填充内容">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F4CB;" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="模板" FontSize="12" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button x:Name="CopyLastBtn" Click="CopyLast_Click"
                                    Style="{StaticResource BtnGhost}" Padding="8,6" ToolTip="复制上一条记录的任务和类型">
                                <TextBlock Text="复制上条" FontSize="12"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Button>
                            <Button x:Name="CloseFormBtn" Click="CloseForm_Click"
                                    Style="{StaticResource BtnGhost}" Padding="8,6" ToolTip="关闭面板">
                                <TextBlock Text="&#x2715;" FontSize="14" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                    <Grid>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveRecordCommand}"
                                Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left"
                                Padding="28,11"/>
                        <Button Content="新建" Command="{Binding NewRecordCommand}"
                                Style="{StaticResource BtnSecondary}" HorizontalAlignment="Right"
                                Padding="22,11"/>
                    </Grid>
                    <Border Background="{StaticResource SuccessLightBrush}" CornerRadius="9"
                            Padding="14,10" Margin="0,10,0,0">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"
                                   FontSize="13" FontWeight="Medium"/>
                    </Border>
                </StackPanel>

                <!-- 表单字段 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="0,0,0,16">

                        <!-- 任务 + 类型 -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="任务 *" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding CurrentRecord.ProjectName}"
                                          Style="{StaticResource Select}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="类型 *" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding WorkTypes}" SelectedItem="{Binding CurrentRecord.WorkType}"
                                          Style="{StaticResource Select}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,2,0,14"/>

                        <!-- 快捷模板 -->
                        <TextBlock Text="快捷模板" Style="{StaticResource Label}"/>
                        <ItemsControl ItemsSource="{Binding ContentTemplates}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" Style="{StaticResource BtnGhost}"
                                            Padding="10,5" Margin="0,0,6,6" FontSize="12"
                                            Command="{Binding DataContext.ApplyTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="{StaticResource PrimaryBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 工作内容 -->
                        <TextBlock Text="工作内容 *" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding CurrentRecord.Content}" Height="160"
                                 Style="{StaticResource TextArea}" Margin="0,0,0,6"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="描述做了什么、关键产出和交付物" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,18"/>

                        <!-- 问题与解决方案 -->
                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="14,10" Margin="0,0,0,18" Cursor="Hand">
                            <StackPanel>
                                <CheckBox x:Name="ProblemToggle" Content="遇到了问题？点击展开记录"
                                          IsChecked="{Binding HasProblem, Mode=TwoWay}"
                                          FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                                <StackPanel Visibility="{Binding IsChecked, ElementName=ProblemToggle, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                            Margin="0,10,0,4">
                                    <TextBlock Text="问题描述" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding CurrentRecord.Problem}" Height="64"
                                             Style="{StaticResource TextArea}" Margin="0,0,0,10"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="解决方案" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding CurrentRecord.Solution}" Height="64"
                                             Style="{StaticResource TextArea}" Margin="0,0,0,4"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,2,0,18"/>

                        <!-- 工时与进度 -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="10" Padding="14,10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="工时 (小时)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding CurrentRecord.Hours}" Style="{StaticResource Input}"
                                             BorderThickness="0" Background="Transparent" Padding="0,4"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="10" Padding="14,10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="进度 (%)" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding CurrentRecord.Progress}" Style="{StaticResource Input}"
                                             BorderThickness="0" Background="Transparent" Padding="0,4"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 亮点标记 -->
                        <Border Background="{StaticResource WarningLightBrush}" CornerRadius="10"
                                Padding="14,12" BorderBrush="#FFE5D5A0" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="HighlightToggle"
                                          Content="&#x2B50; 标记为工作亮点" FontSize="13" FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          IsChecked="{Binding CurrentRecord.IsHighlight, Converter={x:Static local:BoolToIntConverter.Instance}}"
                                          Margin="0,0,0,8" Cursor="Hand"/>
                                <StackPanel Visibility="{Binding IsChecked, ElementName=HighlightToggle, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                    <TextBox Text="{Binding CurrentRecord.HighlightNote, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextArea}" Height="56"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="简要描述这项工作的亮点和成果" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
