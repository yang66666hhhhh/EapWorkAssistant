<Window x:Class="EapWorkAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
        xmlns:vm="clr-namespace:EapWorkAssistant.ViewModels"
        xmlns:views="clr-namespace:EapWorkAssistant.Views"
        xmlns:svc="clr-namespace:EapWorkAssistant.Services"
        Title="EAP Work Assistant" Height="800" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFont}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="item" Background="Transparent" CornerRadius="10" Margin="8,2"
                                Padding="14,11" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ico" Text="{TemplateBinding Content}" FontSize="15"
                                           Foreground="{StaticResource SidebarTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt" Grid.Column="1"
                                           Text="{TemplateBinding Tag}" Margin="12,0,0,0"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource SidebarTextBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="item"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#FF162033" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                                <MultiTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="item"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.ExitActions>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="item" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4338CA" Offset="0"/>
                                            <GradientStop Color="#FF7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 深色侧边栏 ===== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3" Direction="90"/>
            </Border.Effect>
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="12" Width="44" Height="44">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4338CA" Offset="0"/>
                                    <GradientStop Color="#FF7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.35" Color="#FF4338CA"/>
                            </Border.Effect>
                            <TextBlock Text="EAP" FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{StaticResource MonoFont}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="EAP Work" FontSize="17" FontWeight="Bold" Foreground="White"
                                       FontFamily="{StaticResource DefaultFont}"/>
                            <TextBlock Text="Assistant v2.0" FontSize="11" Foreground="#FF64748B"
                                       FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 底部卡片（点击打开个人信息） -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20" CornerRadius="12" Padding="16"
                        Cursor="Hand" MouseLeftButtonDown="ProfileCard_Click">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF1E293B" Offset="0"/>
                            <GradientStop Color="#FF253349" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <!-- 头像：显示姓名首字 -->
                            <Border Width="34" Height="34" CornerRadius="17" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF4338CA" Offset="0"/>
                                        <GradientStop Color="#FF7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=AvatarInitial}"
                                           FontSize="15" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="44,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Name}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Role}"
                                           FontSize="11" Foreground="#FF64748B"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="#FF0F172A" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Industry}"
                                           FontSize="11" Foreground="#FF64748B"/>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Department}"
                                           FontSize="12" Foreground="#FF94A3B8" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 分隔线 -->
                <Border DockPanel.Dock="Bottom" Height="1" Background="#FF1E293B" Margin="24,0,24,16"/>

                <!-- 导航 -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#FF475569" Margin="24,0,0,14"
                                   FontFamily="{StaticResource MonoFont}"/>
                        <RadioButton Style="{StaticResource NavButton}" IsChecked="True"
                                     Content="&#x1F4CA;" Tag="工作台"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F4DD;" Tag="工作记录"
                                     Command="{Binding NavigateToCommand}" CommandParameter="WorkRecord"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F4DA;" Tag="知识库"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Knowledge"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F527;" Tag="问题跟踪"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Issue"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x2699;" Tag="设置"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}">
            <DockPanel>
                <!-- 顶部搜索栏 -->
                <Border DockPanel.Dock="Top" Background="White" Padding="16,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid Height="40">
                        <Border CornerRadius="10" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                         Padding="40,0,16,0" VerticalContentAlignment="Center"
                                         CaretBrush="{StaticResource PrimaryBrush}"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"/>
                                <Border Background="Transparent" VerticalAlignment="Center"
                                        Margin="14,0,0,0" IsHitTestVisible="False">
                                    <TextBlock Text="&#x1F50D;" FontSize="14" Opacity="0.4"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="搜索工作记录、知识库、问题..." FontSize="13"
                                           VerticalAlignment="Center" Margin="40,0,0,0"
                                           Opacity="0.35" IsHitTestVisible="False"
                                           Foreground="{StaticResource TextTertiaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                CornerRadius="6" Padding="8,5"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <TextBlock Text="Ctrl+F 聚焦搜索" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 主内容 -->
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkRecordViewModel}">
                            <views:WorkRecordView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:KnowledgeViewModel}">
                            <views:KnowledgeView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:IssueViewModel}">
                            <views:IssueView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <views:SettingsView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </DockPanel>
        </Border>

        <!-- ===== 搜索结果弹窗 ===== -->
        <Border x:Name="SearchPopup" Panel.ZIndex="100"
                Visibility="{Binding IsSearchPopupOpen, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                CornerRadius="14"
                Margin="260,60,20,20" MaxHeight="500"
                HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Border.Background>
                <SolidColorBrush Color="White" Opacity="0.98"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.2" Color="#FF000000"/>
            </Border.Effect>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="18,14,18,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="6"
                                        Width="28" Height="28" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F50D;" FontSize="12" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="搜索结果" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="10,5">
                                <TextBlock Text="{Binding SearchResults.Count, StringFormat=共 {0} 条}" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                            </Border>
                        </Grid>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10,0,0" Opacity="0.5"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="12,10" Margin="10,3"
                                            Cursor="Hand" MouseLeftButtonDown="SearchResult_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="9" Width="38" Height="38">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource Primary}" Opacity="0.1"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Icon}" FontSize="15"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                                    <Border CornerRadius="4" Padding="8,3" Margin="8,0,0,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{StaticResource Primary}" Opacity="0.08"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Medium"
                                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Content}" FontSize="12"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border DockPanel.Dock="Bottom" Margin="16,4,16,14" Padding="10,6"
                            CornerRadius="8">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource Primary}" Opacity="0.05"/>
                        </Border.Background>
                        <TextBlock FontSize="11" HorizontalAlignment="Center">
                            <Run Foreground="{StaticResource TextTertiaryBrush}" Text="按 "/>
                            <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" Text="Esc"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" Text=" 关闭 · "/>
                            <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" Text="Enter"/>
                            <Run Foreground="{StaticResource TextTertiaryBrush}" Text=" 搜索"/>
                        </TextBlock>
                    </Border>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</Window>
