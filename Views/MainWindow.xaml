<Window x:Class="EapWorkAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
        xmlns:vm="clr-namespace:EapWorkAssistant.ViewModels"
        xmlns:views="clr-namespace:EapWorkAssistant.Views"
        xmlns:svc="clr-namespace:EapWorkAssistant.Services"
        Title="EAP Work Assistant" Height="800" Width="1320"
        Icon="pack://application:,,,/Resources/app.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFont}">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="item" Background="Transparent" CornerRadius="10" Margin="8,2"
                                Padding="14,11" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ico" Text="{TemplateBinding Content}" FontSize="15"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt" Grid.Column="1"
                                           Text="{TemplateBinding Tag}" Margin="12,0,0,0"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="item"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#FF162033" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                                <MultiTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="item"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.ExitActions>
                            </MultiTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="item" Property="Background" Value="{DynamicResource PrimaryGradient}"/>
                                <Setter TargetName="ico" Property="Foreground" Value="White"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 侧边栏（适配亮/暗色主题） ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3" Direction="90"/>
            </Border.Effect>
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="12" Width="44" Height="44"
                                Background="{DynamicResource PrimaryGradient}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.25"/>
                            </Border.Effect>
                            <TextBlock Text="EAP" FontSize="13" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{StaticResource MonoFont}"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="EAP Work" FontSize="17" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource DefaultFont}"/>
                            <TextBlock Text="Assistant v2.0" FontSize="11"
                                       Foreground="{DynamicResource SidebarTextBrush}"
                                       FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 底部卡片（点击打开个人信息） -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20" CornerRadius="12" Padding="16"
                        Cursor="Hand" MouseLeftButtonDown="ProfileCard_Click"
                        Background="{DynamicResource SidebarCardBgBrush}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <!-- 头像：首字母 / 上传图片 -->
                            <Border Width="34" Height="34" CornerRadius="17" HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryGradient}">
                                <Grid>
                                    <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=AvatarInitial}"
                                               FontSize="15" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- 头像图片层 -->
                                    <Border CornerRadius="17"
                                            Visibility="{Binding Source={x:Static svc:ProfileService.Instance}, Path=HasAvatar, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                        <Border.Background>
                                            <ImageBrush Stretch="UniformToFill"
                                                        ImageSource="{Binding Source={x:Static svc:ProfileService.Instance}, Path=AvatarPath, Converter={x:Static local:AvatarPathConverter.Instance}}"/>
                                        </Border.Background>
                                    </Border>
                                    <!-- 悬浮编辑提示 -->
                                    <Border x:Name="SidebarAvatarOverlay" CornerRadius="17"
                                            Background="#50000000" Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="&#x270E;" FontSize="12" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <StackPanel Margin="44,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Name}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Role}"
                                           FontSize="11" Foreground="{DynamicResource SidebarTextBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="{DynamicResource SidebarCardBgBrush}" CornerRadius="8" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Industry}"
                                           FontSize="11" Foreground="{DynamicResource SidebarTextBrush}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:ProfileService.Instance}, Path=Department}"
                                           FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 分隔线 -->
                <Border DockPanel.Dock="Bottom" Height="1" Background="{DynamicResource SidebarTextBrush}" Margin="24,0,24,16" Opacity="0.2"/>

                <!-- 导航 -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SidebarTextBrush}" Margin="24,0,0,14"
                                   FontFamily="{StaticResource MonoFont}"/>
                        <RadioButton Style="{StaticResource NavButton}" IsChecked="True"
                                     Content="&#x1F4CA;" Tag="工作台" ToolTip="工作台"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F4DD;" Tag="工作记录" ToolTip="工作记录"
                                     Command="{Binding NavigateToCommand}" CommandParameter="WorkRecord"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F4DA;" Tag="知识库" ToolTip="知识库"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Knowledge"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x1F527;" Tag="问题跟踪" ToolTip="问题跟踪"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Issue"/>
                        <RadioButton Style="{StaticResource NavButton}"
                                     Content="&#x2699;" Tag="设置" ToolTip="设置"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Column="1" x:Name="MainContentArea">

            <!-- 子视图内容（全区域，不占位） -->
            <Border Background="{DynamicResource SurfaceBrush}">
                <ContentControl Content="{Binding CurrentView}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkRecordViewModel}">
                            <views:WorkRecordView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:KnowledgeViewModel}">
                            <views:KnowledgeView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:IssueViewModel}">
                            <views:IssueView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <views:SettingsView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>

            <!-- ===== Spotlight 风格居中搜索 ===== -->
            <!-- 全屏遮罩 -->
            <Border Panel.ZIndex="50" x:Name="SearchOverlayBorder"
                    Background="#40000000" MouseLeftButtonDown="SearchOverlay_Click"
                    Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                                <Setter Property="IsHitTestVisible" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- 居中搜索面板 -->
            <Border Panel.ZIndex="60" x:Name="SearchPanelBorder"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Width="540" Margin="0,80,0,0"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             From="-20" To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="-15" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                                <Setter Property="IsHitTestVisible" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border CornerRadius="14" Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.2" Color="#FF000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 搜索输入框 -->
                        <Border Padding="18,0" Height="48" BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource BorderBrush}">
                            <Grid>
                                <TextBlock Text="&#x1F50D;" FontSize="16" Opacity="0.4"
                                           VerticalAlignment="Center" HorizontalAlignment="Left"
                                           IsHitTestVisible="False"/>
                                <TextBox x:Name="MainSearchBox" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15"
                                         Padding="28,0,8,0" VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource PrimaryBrush}"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="SearchBox_KeyDown"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>
                                <TextBlock x:Name="SearchPlaceholder" FontSize="13"
                                           VerticalAlignment="Center" Margin="28,0,0,0"
                                           Opacity="0.35" IsHitTestVisible="False"
                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=MainSearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- 搜索结果滚动区 -->
                        <ScrollViewer x:Name="SearchResultsPanel" Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <Grid>
                                <!-- 搜索中状态 -->
                                <Border Visibility="{Binding IsSearching, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                        Padding="20,28">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F50D;" FontSize="22" HorizontalAlignment="Center" Opacity="0.3"/>
                                        <TextBlock Text="正在搜索..." FontSize="13"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 无结果状态 -->
                                <Border Visibility="{Binding ShowNoResults, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                        Padding="20,28">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F50D;" FontSize="22" HorizontalAlignment="Center" Opacity="0.3"/>
                                        <TextBlock Text="未找到相关内容" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <TextBlock Text="试试其他关键词" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 初始状态 -->
                                <Border Visibility="{Binding ShowInitial, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                                        Padding="20,24">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2328;&#xFE0F;" FontSize="22" HorizontalAlignment="Center" Opacity="0.3"/>
                                        <TextBlock Text="输入关键词，实时搜索全部内容" FontSize="13"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        <TextBlock FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0">
                                            <Run Foreground="{DynamicResource TextTertiaryBrush}" Text="自动搜索 · "/>
                                            <Run Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Text="Esc"/>
                                            <Run Foreground="{DynamicResource TextTertiaryBrush}" Text=" 关闭"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 搜索结果列表 -->
                                <ItemsControl ItemsSource="{Binding SearchResults}"
                                              Visibility="{Binding ShowResults, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="14,10" Margin="8,3"
                                                    Cursor="Hand" MouseLeftButtonDown="SearchResult_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="38"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="8" Width="38" Height="38">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{DynamicResource Primary}" Opacity="0.1"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding Icon}" FontSize="15"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="320"
                                                                       local:Highlight.Text="{Binding Title}"
                                                                       local:Highlight.Keyword="{Binding Keyword}"/>
                                                            <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{DynamicResource Primary}" Opacity="0.08"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Medium"
                                                                           Foreground="{DynamicResource PrimaryBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                                                   local:Highlight.Text="{Binding Content}"
                                                                   local:Highlight.Keyword="{Binding Keyword}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>

                        <!-- 底部提示栏 -->
                        <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource BorderBrush}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Text="Ctrl+F 打开 · "/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Text="Enter"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Text=" 立即搜索 · "/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Text="Esc"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Text=" 关闭"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <!-- ===== Toast 通知浮层 ===== -->
            <Border Grid.Column="1" Panel.ZIndex="70"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,24,24">
                <ItemsControl ItemsSource="{Binding Source={x:Static svc:ToastService.Instance}, Path=Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ToastCard" CornerRadius="10" Padding="16,12"
                                    Margin="0,0,0,8" MinWidth="280" MaxWidth="380"
                                    IsHitTestVisible="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Effect="{StaticResource ShadowMd}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                                            VerticalAlignment="Top" Margin="0,0,12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Success">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Error">
                                                        <Setter Property="Background" Value="{DynamicResource DangerLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Info">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Success">
                                                            <Setter Property="Text" Value="&#x2713;"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Error">
                                                            <Setter Property="Text" Value="&#x2717;"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Info">
                                                            <Setter Property="Text" Value="&#x2139;"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Message}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="&#x2715;" FontSize="11"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TextTertiaryBrush}"
                                            Padding="4" Margin="8,0,0,0" Cursor="Hand"
                                            VerticalAlignment="Top"
                                            Command="{Binding Source={x:Static svc:ToastService.Instance}, Path=DismissCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToastCard"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="ToastCard"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="40" To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <DataTrigger Binding="{Binding IsDismissing}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ToastCard"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetName="ToastCard"
                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                 From="0" To="30" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
