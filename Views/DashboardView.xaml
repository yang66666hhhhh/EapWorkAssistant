<UserControl x:Class="EapWorkAssistant.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EapWorkAssistant.Helpers"
             xmlns:views="clr-namespace:EapWorkAssistant.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             FontFamily="{StaticResource DefaultFont}">
    <Grid>
    <ScrollViewer x:Name="MainScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Style="{StaticResource ModernScrollViewer}">
        <StackPanel Margin="28,24,28,28">

            <!-- ===== 顶部标题栏 ===== -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="工作台" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="欢迎回来！以下是您的工作概览。"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                            Padding="14,9" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CurrentDate, Mode=OneWay}"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== 统计卡片行 ===== -->
            <Grid Margin="0,0,0,14"
                  Visibility="{Binding ShowDashStats, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 今日工时 -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="今日工时" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding TodayHours, Mode=OneWay, StringFormat={}{0:F1}}" FontSize="28"
                                           FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text="h" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconClock}" Fill="{DynamicResource PrimaryBrush}" Width="17" Height="17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 本周工时 -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="本周工时" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding WeekHours, Mode=OneWay, StringFormat={}{0:F1}}" FontSize="28"
                                           FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                <TextBlock Text="h" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource SuccessBrush}" Width="17" Height="17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 本月工时 -->
                <Border Grid.Column="4" Style="{StaticResource Card}" Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="本月工时" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding MonthHours, Mode=OneWay, StringFormat={}{0:F1}}" FontSize="28"
                                           FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="h" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconChart}" Fill="{DynamicResource WarningBrush}" Width="17" Height="17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 总记录 -->
                <Border Grid.Column="6" Style="{StaticResource Card}" Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="总记录" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding TotalRecords, Mode=OneWay}" FontSize="28"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentVioletBrush}"/>
                                <TextBlock Text="条" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,6"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconPencil}" Fill="{DynamicResource AccentVioletBrush}" Width="17" Height="17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== 今日提醒 ===== -->
            <Border CornerRadius="14" Margin="0,0,0,14" Padding="1.5"
                    Visibility="{Binding ShowDashReminder, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                    Background="{DynamicResource AccentBannerGradient}">
                <Border Background="{DynamicResource CardBrush}" CornerRadius="13" Padding="18,14">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="10"
                                    Width="42" Height="42" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Path Data="{StaticResource IconPencil}" Fill="{DynamicResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="今日记录" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding TodayReminderText}" FontSize="14"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Visibility="{Binding IsProbation, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14,8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconTarget}" Fill="{DynamicResource TextPrimaryBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <Run Text="试用期剩余 "/>
                                        <Run Text="{Binding ProbationRemainingDays, Mode=OneWay}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                        <Run Text=" 天"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>

            <!-- ===== 覆盖率提醒 ===== -->
            <Border Visibility="{Binding ShowCoverageWarning, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                    Background="{DynamicResource WarningLightBrush}" CornerRadius="10" Padding="16,12"
                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconWarning}" Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding CoverageWarningText}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ===== 补充统计行 ===== -->
            <Grid Margin="0,0,0,14"
                  Visibility="{Binding ShowDashStats, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="18,14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="问题解决" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding TotalIssues, Mode=OneWay}" FontSize="24"
                                           FontWeight="Bold" Foreground="{DynamicResource DangerBrush}"/>
                                <TextBlock Text="个" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,5"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource DangerLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconWrench}" Fill="{DynamicResource DangerBrush}" Width="17" Height="17" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="18,14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="知识文章" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontWeight="Medium"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding TotalKnowledge, Mode=OneWay}" FontSize="24"
                                           FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text="篇" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="3,0,0,5"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8"
                                Width="38" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconClipboard}" Fill="{DynamicResource PrimaryBrush}"
                                  Width="18" Height="18" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== 试用期进度（仅试用期员工显示） ===== -->
            <Border CornerRadius="14" Margin="0,0,0,14" Padding="1.5"
                    Visibility="{Binding ShowDashProbation, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"
                    Background="{DynamicResource AccentBannerGradient}">
                <Border Background="{DynamicResource CardBrush}" CornerRadius="13" Padding="24">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconTarget}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="试用期进度" FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ProbationInfo}" FontSize="13"
                                               Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="开始日期：" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Border x:Name="ProbDateBtn" Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Padding="10,0" Height="34" VerticalAlignment="Center"
                                            Cursor="Hand" MouseLeftButtonDown="ProbDateBtn_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource TextPrimaryBrush}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                                            <TextBlock x:Name="ProbDateText" FontSize="12.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 时间进度 -->
                            <Border Grid.Column="0" x:Name="ProbProgressParent"
                                    Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                    Padding="18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="时间进度" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding ProbationProgressPercent, StringFormat={}{0:F0}}" FontSize="30"
                                                   FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="%" FontSize="16" Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,6"/>
                                    </StackPanel>
                                    <Grid Height="8" Margin="0,10,0,0">
                                        <Border Background="{DynamicResource BorderBrush}" CornerRadius="4"/>
                                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                    <Binding Path="ProbationProgressPercent"/>
                                                    <Binding Path="ActualWidth" ElementName="ProbProgressParent"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,0">
                                        <Run Text="已过 "/><Run Text="{Binding ProbationDaysPassed, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding ProbationDaysTotal, Mode=OneWay}"/><Run Text=" 天"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 记录覆盖率 -->
                            <Border Grid.Column="2" x:Name="CoverageProgressParent"
                                    Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                    Padding="18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="记录覆盖率" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding CoverageRatePercent, StringFormat={}{0:F0}}" FontSize="30"
                                                   FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                        <TextBlock Text="%" FontSize="16" Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Bottom" Margin="2,0,0,6"/>
                                    </StackPanel>
                                    <Grid Height="8" Margin="0,10,0,0">
                                        <Border Background="{DynamicResource BorderBrush}" CornerRadius="4"/>
                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="4"
                                                HorizontalAlignment="Left">
                                            <Border.Width>
                                                <MultiBinding Converter="{x:Static local:PercentToWidthConverter.Instance}">
                                                    <Binding Path="CoverageRatePercent"/>
                                                    <Binding Path="ActualWidth" ElementName="CoverageProgressParent"/>
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                    </Grid>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,0">
                                        <Run Text="有记录工作日："/><Run Text="{Binding RecordedDaysCount, Mode=OneWay}"/><Run Text=" 天"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 转正述职按钮 -->
                            <Border Grid.Column="4" Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                    Padding="18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconPencil}" Fill="{DynamicResource TextPrimaryBrush}" Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="转正述职报告" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <Button Content="一键生成" Command="{Binding GenerateProbationReportCommand}"
                                            Style="{StaticResource BtnPrimary}" Margin="0,14,0,0"
                                            HorizontalAlignment="Center" Padding="22,9"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Border>

            <!-- ===== 工时趋势 + 项目分布 + 亮点列表 ===== -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 工时趋势图表 -->
                <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="22"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding ShowDashCharts, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconTrend}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="本周工时趋势" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="每日工时分布" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid>
                            <lvc:CartesianChart Series="{Binding ChartSeries}"
                                                XAxes="{Binding ChartXAxes}"
                                                YAxes="{Binding ChartYAxes}"
                                                DataPointerDownCommand="{Binding ChartPointClickCommand}"
                                                MinHeight="190" MaxHeight="210"/>
                            <Border Visibility="{Binding HasChartData, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}"
                                    Background="{DynamicResource CardBrush}" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconTrend}" Fill="{DynamicResource TextPrimaryBrush}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                    <TextBlock Text="暂无工时数据" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="开始记录工作后将自动生成图表" FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- 项目分布饼图 -->
                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="22"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding ShowDashCharts, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconChart}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="本月项目分布" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="各项目工时占比" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid>
                            <lvc:PieChart Series="{Binding ProjectPieSeries}"
                                          DataPointerDownCommand="{Binding PieChartClickCommand}"
                                          MinHeight="190" MaxHeight="210"/>
                            <Border Visibility="{Binding HasPieData, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}"
                                    Background="{DynamicResource CardBrush}" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconChart}" Fill="{DynamicResource TextPrimaryBrush}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                    <TextBlock Text="暂无项目数据" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="记录工作后将显示项目分布" FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- 亮点列表 -->
                <Border Grid.Column="4" Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="22"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding ShowDashHighlights, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconStar}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="工作亮点" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="标记的重要成果" FontSize="12"
                                       Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Grid>
                            <ItemsControl ItemsSource="{Binding Highlights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                                                Padding="14,10" Margin="0,0,0,6"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Note}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxHeight="38"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border Style="{StaticResource TagPrimary}">
                                                        <TextBlock Text="{Binding ProjectName}" FontSize="10"
                                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding WorkDate}" FontSize="11"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 空状态 -->
                            <Border Visibility="{Binding Highlights.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                                    Padding="20">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconStar}" Fill="{DynamicResource TextPrimaryBrush}" Width="36" Height="36" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                    <TextBlock Text="暂无亮点记录" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="在「工作记录」中勾选&#x201C;亮点&#x201D;标记" FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ===== 转正述职材料（仅试用期员工显示） ===== -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,14"
                    Visibility="{Binding IsProbation, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconSparkle}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="转正述职材料" FontSize="16"
                                               FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="自动生成试用期工作总结，用于转正评审"
                                           FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="生成报告" Command="{Binding GenerateProbationReportCommand}"
                                        Style="{StaticResource BtnPrimary}" Padding="16,8"/>
                                <Button Content="复制" Command="{Binding CopyReportCommand}"
                                        Style="{StaticResource BtnGhost}" Margin="6,0,0,0" Padding="12,8"
                                        Foreground="{DynamicResource SuccessBrush}"/>
                                <Button Content="保存" Command="{Binding SaveReportCommand}"
                                        Style="{StaticResource BtnGhost}" Margin="6,0,0,0" Padding="12,8"
                                        Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="18">
                        <TextBox Text="{Binding ProbationReport}" IsReadOnly="True" TextWrapping="Wrap"
                                 AcceptsReturn="True" MinHeight="180" MaxHeight="360"
                                 VerticalScrollBarVisibility="Auto" BorderThickness="0"
                                 Background="Transparent" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontFamily="{StaticResource MonoFont}"/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ===== 最近工作记录 ===== -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="14" Padding="24"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    ClipToBounds="True"
                    Visibility="{Binding ShowDashRecent, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconClipboard}" Fill="{DynamicResource TextPrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="最近工作记录" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="最近5条工作记录，快速回顾近期工作"
                                           FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Style="{StaticResource TagPrimary}" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Padding="10,5">
                                <TextBlock Text="{Binding TotalRecords, StringFormat=共 {0} 条}" FontSize="11"
                                           Foreground="{DynamicResource PrimaryBrush}" FontWeight="Medium"/>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Grid>
                        <DataGrid ItemsSource="{Binding RecentRecords}" Style="{StaticResource ModernGrid}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  ClipboardCopyMode="IncludeHeader">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernGridColumnHeader}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernGridCell}"/>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernGridRow}"/>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="日期" Binding="{Binding WorkDate}" Width="136"/>
                                <DataGridTextColumn Header="任务" Binding="{Binding ProjectName}" Width="156"/>
                                <!-- 类型 - 彩色标签 -->
                                <DataGridTemplateColumn Header="类型" Width="96"
                                                        ClipboardContentBinding="{Binding WorkType}"
                                                        CellTemplate="{StaticResource WorkTypeBadgeCell}"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Content}" Width="260" MinWidth="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="工作成果" Binding="{Binding Achievement}" Width="220" MinWidth="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="工时" Binding="{Binding Hours, StringFormat={}{0:F1}h}" Width="80"/>
                                <!-- 进度 - 进度条 -->
                                <DataGridTemplateColumn Header="进度" Width="144"
                                                        ClipboardContentBinding="{Binding Progress, StringFormat={}{0}%}"
                                                        CellTemplate="{StaticResource ProgressBarCell}"/>
                                <DataGridTextColumn Header="问题" Binding="{Binding Problem}" Width="220" MinWidth="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTextTrim}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 空状态 -->
                        <Border Visibility="{Binding RecentRecords.Count, Converter={x:Static local:CountToVisibilityConverter.Instance}}"
                                Padding="40" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconClipboard}" Fill="{DynamicResource TextPrimaryBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.25"/>
                                <TextBlock Text="暂无工作记录" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
                                <TextBlock Text="前往「工作记录」页面开始记录您的工作" FontSize="12"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <!-- ===== 日历浮窗（试用期开始日期选择） ===== -->
    <Border x:Name="CalendarBackdrop" Style="{StaticResource CalendarOverlay}"
            MouseLeftButtonDown="CalendarBackdrop_Click"
            Panel.ZIndex="50"/>
    <Border x:Name="CalendarContainer" Style="{StaticResource FloatingPanel}"
            Margin="20,90,0,0" Panel.ZIndex="51"
            Width="310">
        <views:CustomCalendar x:Name="CustomCal"
                              SelectedDate="{Binding CalendarDate, Mode=TwoWay}"/>
    </Border>
    </Grid>
</UserControl>
