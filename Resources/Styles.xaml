<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:local="clr-namespace:EapWorkAssistant.Helpers">

    <!-- ==================== 颜色体系（Refined Precision） ==================== -->
    <Color x:Key="Primary">#FF4338CA</Color>
    <Color x:Key="PrimaryHover">#FF3630AE</Color>
    <Color x:Key="PrimaryLight">#FFE9EEFF</Color>
    <Color x:Key="PrimarySoft">#FFF3F5FF</Color>
