    <!-- ==================== 字体 ==================== -->
    <FontFamily x:Key="DefaultFont">Microsoft YaHei UI, Segoe UI, Segoe UI Emoji</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>

    <!-- 字体大小（可被 ThemeService 动态修改） -->
    <sys:Double x:Key="BaseFontSize">13</sys:Double>
    <sys:Double x:Key="SmallFontSize">12</sys:Double>
    <sys:Double x:Key="Heading3FontSize">16</sys:Double>
    <sys:Double x:Key="BodyFontSize">13</sys:Double>
    <sys:Double x:Key="CaptionFontSize">11</sys:Double>

    <!-- 全局 UI 缩放因子（字体大小联动） -->
    <sys:Double x:Key="UIScale">1.0</sys:Double>

    <!-- 界面密度间距（ThemeService 动态修改，Thickness 类型） -->
    <Thickness x:Key="DensityCardPad">24</Thickness>
    <Thickness x:Key="DensityRowPad">20,14</Thickness>
    <Thickness x:Key="DensityRowPadSm">18,11</Thickness>
    <Thickness x:Key="DensityListPad">14,12</Thickness>
    <Thickness x:Key="DensitySectionMargin">0,0,0,18</Thickness>
    <Thickness x:Key="DensityRowMargin">0,0,0,6</Thickness>
    <Thickness x:Key="DensityItemMargin">0,0,0,12</Thickness>

    <!-- ==================== 阴影效果（更精致） ==================== -->
    <DropShadowEffect x:Key="ShadowSm" BlurRadius="16" ShadowDepth="1" Opacity="0.045" Color="#FF000000"/>
    <DropShadowEffect x:Key="ShadowMd" BlurRadius="28" ShadowDepth="4" Opacity="0.075" Color="#FF000000"/>
    <DropShadowEffect x:Key="ShadowLg" BlurRadius="44" ShadowDepth="8" Opacity="0.11" Color="#FF000000"/>
    <DropShadowEffect x:Key="ShadowFocus" BlurRadius="14" ShadowDepth="0" Opacity="0.16" Color="#FF6366F1"/>

    <!-- ==================== 动画 ==================== -->
    <Storyboard x:Key="FadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
    </Storyboard>

