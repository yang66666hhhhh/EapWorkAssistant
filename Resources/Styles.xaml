    <!-- 渐变画笔 -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF4338CA" Offset="0"/>
        <GradientStop Color="#FF7C3AED" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentGradientH" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FF4338CA" Offset="0"/>
        <GradientStop Color="#FF7C3AED" Offset="0.5"/>
        <GradientStop Color="#FF4338CA" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentBannerGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FF6366F1" Offset="0"/>
        <GradientStop Color="#FF4F46E5" Offset="0.5"/>
        <GradientStop Color="#FFA5B4FC" Offset="1"/>
    </LinearGradientBrush>

