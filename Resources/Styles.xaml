    <Color x:Key="Warning">#FFD97706</Color>
    <Color x:Key="WarningLight">#FFFEF3C7</Color>
    <Color x:Key="Danger">#FFDC2626</Color>
    <Color x:Key="DangerLight">#FFFEF2F2</Color>
    <Color x:Key="Surface">#FFF4F6FB</Color>
    <Color x:Key="SurfaceHover">#FFECF0F8</Color>
    <Color x:Key="SurfaceAlt">#FFF8FAFD</Color>
    <Color x:Key="CardColor">#FFFFFFFF</Color>
    <Color x:Key="TextPrimary">#FF0F172A</Color>
