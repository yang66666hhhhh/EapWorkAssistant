    <Color x:Key="AccentViolet">#FF7C3AED</Color>
    <Color x:Key="AccentCyan">#FF0891B2</Color>
    <Color x:Key="AccentRose">#FFE11D48</Color>
    <Color x:Key="AccentAmber">#FFF59E0B</Color>
